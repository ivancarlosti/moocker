# Default port to expose the application locally.
MOODLE_PORT=8080

# The Public URL of your Moodle instance. 
# If using a reverse proxy, set this to your domains URL (e.g. https://moodle.yourdomain.com)
MOODLE_URL=http://localhost:8080

DB_NAME=moodle
DB_USER=moodleuser
DB_PASSWORD=moodlepass
DB_ROOT_PASSWORD=rootpass
